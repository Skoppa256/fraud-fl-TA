# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/

# =============================================================================
# Jupyter
# =============================================================================
.ipynb_checkpoints/
*-checkpoint.ipynb

# =============================================================================
# Virtual environments / conda
# =============================================================================
.venv/
venv/
env/
ENV/
# Stray conda env folders if accidentally created inside the project
envs/
conda-meta/

# =============================================================================
# Data (large, downloaded locally, not committed)
# =============================================================================
data/
*.csv
*.csv.gz
*.parquet
*.pkl
*.h5
*.hdf5
*.zip
*.tar
*.tar.gz
*.feather

# =============================================================================
# Results / experiment outputs
# =============================================================================
results/
outputs/
multirun/
*.log
logs/

# =============================================================================
# Model artifacts (trained weights / serialized models)
# =============================================================================
*.pt
*.pth
*.joblib
*.model
*.bin
*.onnx
*.ckpt
*.safetensors

# =============================================================================
# Hydra (defensive — already covered by outputs/multirun)
# =============================================================================
.hydra/

# =============================================================================
# Weights & Biases
# =============================================================================
wandb/

# =============================================================================
# SHAP / experiment artifacts
# =============================================================================
shap_values/
shap_cache/
*.shap

# =============================================================================
# Environment files (secrets)
# =============================================================================
.env
*.env
.env.*
!*.env.example

# =============================================================================
# IDE / editor / OS
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# =============================================================================
# Project-specific exceptions (re-include things matched by broad rules above)
# =============================================================================
# Keep the result CSVs that ship with the fedxgbllr baseline (small, committed)
!models/fedxgbllr/results.csv
!models/fedxgbllr/results_centralized.csv
# Keep checked-in PCA visualizations (small reference plots)
!results/visualizations/
!results/visualizations/*.png
